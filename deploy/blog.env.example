# 复制到服务器：/var/data/blog.env（不要提交到 Git）
# sudo cp deploy/blog.env.example /var/data/blog.env && sudo chmod 600 /var/data/blog.env && sudo nano /var/data/blog.env
#
# 然后在项目目录建立软链（一次即可）：
#   ln -sf /var/data/blog.env /var/www/blog/.env.production
#
# Next.js 约定：PM2 也会读取同一份文件（见 ecosystem.config.cjs），
# git pull 不会覆盖 /var/data/blog.env，部署不会重置密码。

ADMIN_PASSWORD=请改为强密码
POSTS_DIR=/var/data/blog-posts
COMMENTS_DIR=/var/data/blog-comments
COMMENT_CAPTCHA_SECRET=请改为 openssl rand -hex 32 生成的随机串
COMMENT_SENSITIVE_WORDS=赌博,色情,诈骗,辱骂,反动

# 若长期用 http://（非 https）访问后台，取消下行注释，否则登录 Cookie 可能无法保存
# ALLOW_HTTP_ADMIN=1

# 可选：后台自助改密写入的文件（与 ADMIN_PASSWORD 二选一持久化，见 README）
# ADMIN_PASSWORD_FILE=/var/data/blog-admin.json
