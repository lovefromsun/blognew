# 后台管理密码（生产环境必须设置）
ADMIN_PASSWORD=your-secure-password

# 可选：文章存储目录（建议生产环境设置为项目目录外，如 /var/data/blog-posts）
# POSTS_DIR=/var/data/blog-posts
# 可选：评论存储目录（建议生产环境设置为项目目录外，如 /var/data/blog-comments）
# COMMENTS_DIR=/var/data/blog-comments
# 可选：评论验证码签名密钥（建议生产环境设置独立密钥）
# COMMENT_CAPTCHA_SECRET=your-captcha-secret
# 可选：敏感词列表（逗号分隔），命中后自动驳回
# COMMENT_SENSITIVE_WORDS=赌博,色情,诈骗,辱骂,反动

# 可选：会话签名密钥，不设置则使用 ADMIN_PASSWORD
# ADMIN_SECRET=your-32-char-secret-key
